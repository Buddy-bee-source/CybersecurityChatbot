<Window x:Class="CybersecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="700" Width="900"
        MinHeight="500" MinWidth="650"
        Background="#808080"
        WindowStartupLocation="CenterScreen">
<!--GUI Layout-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0 - Header -->
        <Border Grid.Row="0"
                Background="#A9A9A9"
                BorderBrush="#000000"
                BorderThickness="0,0,0,2"
                Padding="15,10">
            <StackPanel>
                <TextBlock x:Name="AsciiArtDisplay"
                           FontFamily="Courier New"
                           FontSize="11"
                           Foreground="#000000"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="╔══════════════════════════════════════════════════════╗"
                           FontFamily="Courier New"
                           FontSize="12"
                           Foreground="#000000"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="║        CYBERSECURITY AWARENESS CHATBOT              ║"
                           FontFamily="Courier New"
                           FontSize="12"
                           Foreground="#000000"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="╚══════════════════════════════════════════════════════╝"
                           FontFamily="Courier New"
                           FontSize="12"
                           Foreground="#000000"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ROW 1 - Chat Display -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="#808080"
                      Padding="10">
            <TextBlock x:Name="ChatDisplay"
                       FontFamily="Courier New"
                       FontSize="13"
                       Foreground="#000000"
                       TextWrapping="Wrap"
                       Padding="10"
                       LineHeight="22"/>
        </ScrollViewer>

        <!-- ROW 2 - Input Row -->
        <Border Grid.Row="2"
                Background="#A9A9A9"
                BorderBrush="#000000"
                BorderThickness="0,2,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput"
                         Grid.Column="0"
                         Height="40"
                         FontFamily="Courier New"
                         FontSize="13"
                         Foreground="#000000"
                         Background="#D3D3D3"
                         BorderBrush="#000000"
                         BorderThickness="1"
                         Padding="8,8"
                         CaretBrush="#000000"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInput_KeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="SEND ▶"
                        Width="90"
                        Height="40"
                        FontFamily="Courier New"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#000000"
                        Background="#A9A9A9"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#A9A9A9"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#808080"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>
            